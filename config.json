{
  "host": "0.0.0.0",
  "port": 8443,
  "max_retries": 3,
  "connect_timeout": 5.0,
  "stream_timeout": 60.0,
  "health_check_interval": 10.0,
  "health_check_path": "/health",

  "tls": {
    "enabled": false,
    "cert": "certs/server.crt",
    "key":  "certs/server.key"
  },

  "backends": [
    { "host": "127.0.0.1", "port": 8001 },
    { "host": "127.0.0.1", "port": 8002 },
    { "host": "127.0.0.1", "port": 8003 }
  ]
}